# Copy to .env and fill in. Only OPENAI_API_KEY is required to run the agent.
# The Arize keys enable tracing, datasets, experiments, and online evals.

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# Arize (app.arize.com -> Settings -> Space API Keys)
ARIZE_SPACE_ID=U3BhY2U6...
ARIZE_API_KEY=ak-...
# Project name traces/evals are logged under (auto-created on first trace).
ARIZE_PROJECT=arize-singapore-workshop

# Optional overrides
# OPENAI_MODEL=gpt-4o-mini                 # agent (workhorse) chat model
# EMBEDDING_MODEL=text-embedding-3-small   # knowledge-base embeddings
# JUDGE_MODEL=gpt-4o-mini                  # LLM-as-a-judge model for evals
