# Copy to .env and fill in. Only GOOGLE_API_KEY is required to run the agent.
# The Arize keys enable tracing, datasets, experiments, and online evals.

# Google AI Studio API key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=...

# Arize (app.arize.com -> Settings -> Space API Keys)
ARIZE_SPACE_ID=U3BhY2U6...
ARIZE_API_KEY=ak-...
# Project name traces/evals are logged under (auto-created on first trace).
ARIZE_PROJECT=arize-singapore-workshop

# Optional overrides
# GEMINI_MODEL=gemini-2.5-flash            # agent + judge chat model
# EMBEDDING_MODEL=gemini-embedding-2       # knowledge-base embeddings
# JUDGE_MODEL=gemini-2.5-flash             # LLM-as-a-judge model for evals
